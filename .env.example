# Cali configuration
HERMES_FINANCE_TZ=Asia/Jakarta

# Optional custom paths
# HERMES_HOME=/home/username/.hermes
# HERMES_FINANCE_DIR=/home/username/.hermes/finance
# HERMES_FINANCE_DB=/home/username/.hermes/finance/finance.db

# Encrypted offsite backup
FINANCE_RCLONE_REMOTE=
FINANCE_BACKUP_AGE_RECIPIENT=

# Do not enable this unless you understand the privacy risk.
# ALLOW_PLAINTEXT_FINANCE_BACKUP=0
